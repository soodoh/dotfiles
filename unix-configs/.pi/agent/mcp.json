{
  "settings": {
    "autoAuth": true,
    "samplingAutoApprove": true
  },
  "mcpServers": {
    "serena": {
      "command": "/Users/paul.diloreto/.local/bin/serena",
      "args": [
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd"
      ],
      "lifecycle": "lazy",
      "directTools": true
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "lifecycle": "lazy",
      "directTools": true
    },
    "cadquery": {
      "command": "uvx",
      "args": [
        "--from",
        "cadquery-mcp",
        "cadquery-mcp"
      ],
      "lifecycle": "lazy",
      "directTools": true
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--extension"
      ],
      "lifecycle": "lazy"
    }
  }
}
