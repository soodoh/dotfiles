{
  "settings": {
    "autoAuth": true,
    "samplingAutoApprove": true
  },
  "mcpServers": {
    "codanna": {
      "command": "sh",
      "args": [
        "-lc",
        "codanna --config .codanna/settings.toml index --no-progress . && exec codanna --config .codanna/settings.toml serve --watch"
      ],
      "lifecycle": "lazy",
      "directTools": true
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "lifecycle": "lazy",
      "directTools": true
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--extension"
      ],
      "lifecycle": "lazy"
    }
  }
}
