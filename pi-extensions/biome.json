{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		},
		"enabled": true
	},
	"files": {
		"includes": ["**", "!**/coverage", "!**/dist", "!**/node_modules"]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"complexity": {
				"useRegexLiterals": "off"
			},
			"preset": "recommended"
		}
	},
	"vcs": {
		"clientKind": "git",
		"enabled": true,
		"useIgnoreFile": true
	}
}
