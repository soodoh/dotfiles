{
	"name": "pi-extensions",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./packages/auto-session-name/index.ts",
			"./packages/prompt-suggester/src/index.ts",
			"./packages/shared-prompt-history/index.ts",
			"./packages/statusline/index.ts",
			"./packages/llm-hub/index.ts"
		]
	},
	"scripts": {
		"build": "tsc --noEmit",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"ci": "bun run check && bun run typecheck && bun run test:typecheck && bun run test:coverage",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:typecheck": "tsc --noEmit --project tsconfig.test.json",
		"typecheck": "tsc --noEmit",
		"test:coverage:html": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov --coverage.reporter=html"
	},
	"dependencies": {
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/exporter-metrics-otlp-http": "^0.221.0",
		"@opentelemetry/resources": "^2.10.0",
		"@opentelemetry/sdk-metrics": "^2.10.0",
		"proper-lockfile": "4.1.2",
		"typebox": "^1.3.7"
	},
	"peerDependencies": {
		"@earendil-works/pi-agent-core": "*",
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	},
	"devDependencies": {
		"@types/proper-lockfile": "4.1.4"
	}
}
