{
	"name": "pi-extensions",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.12",
	"workspaces": [
		"packages/*"
	],
	"pi": {
		"extensions": [
			"./packages/auto-session-name/index.ts",
			"./packages/prompt-suggester/src/index.ts",
			"./packages/shared-prompt-history/index.ts",
			"./packages/statusline/index.ts",
			"./packages/claude-otel/index.ts",
			"./packages/workflows/index.ts",
			"./packages/llm-hub/index.ts"
		]
	},
	"scripts": {
		"build": "turbo run build",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"ci": "bun run check && bun run typecheck && bun run test:typecheck && bun run test:coverage",
		"test": "turbo run test",
		"test:coverage": "vitest run --coverage",
		"test:typecheck": "tsc --noEmit --project tsconfig.test.json",
		"typecheck": "turbo run typecheck",
		"prepare:lefthook": "node scripts/prepare-lefthook.cjs",
		"test:coverage:html": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov --coverage.reporter=html"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@mariozechner/pi-agent-core": "0.73.1",
		"@mariozechner/pi-ai": "0.73.1",
		"@mariozechner/pi-coding-agent": "0.73.1",
		"@mariozechner/pi-tui": "0.73.1",
		"@types/node": "^26.1.1",
		"@vitest/coverage-v8": "^4.1.10",
		"lefthook": "^2.1.10",
		"turbo": "^2.10.4",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	}
}
